{
  "version": 4,
  "configurations": [
    {
      "name": "Zephyr",
      "compileCommands": "${workspaceFolder}/build/compile_commands.json",
      "compilerPath": "${env:USERPROFILE}/zephyr-sdk-0.17.4/arm-zephyr-eabi/bin/arm-zephyr-eabi-gcc.exe",
      "intelliSenseMode": "gcc-arm",
      "defines": ["__ZEPHYR__=1"],
      "includePath": [
        "${workspaceFolder}/**"
      ],
      "browse": {
        "path": [
          "${workspaceFolder}"
        ],
        "limitSymbolsToIncludedHeaders": true
      }
    }
  ]
}
