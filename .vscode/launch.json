{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Zephyr Attach (Safe Mode)",
            "type": "cortex-debug",
            "request": "attach",   
            "cwd": "${workspaceFolder}",
            "executable": "${workspaceFolder}/build/zephyr/zephyr.elf",
            
            "servertype": "openocd",
            "serverpath": "C:/Tools/openocd/bin/openocd.exe",
            "searchDir": ["C:/Tools/openocd/scripts"],
            
            "gdbPath": "C:/Users/ChuLeeann/Downloads/zephyr-sdk-0.16.9_windows-x86_64/zephyr-sdk-0.16.9/arm-zephyr-eabi/bin/arm-zephyr-eabi-gdb.exe",

            "configFiles": [
                "interface/stlink.cfg", 
                "target/stm32f7x.cfg"
            ],
            
            
            "rttConfig": {
                "enabled": true,
                "address": "auto",
                "decoders": [
                    {
                        "label": "",
                        "port": 0,
                        "type": "console"
                    }
                ]
            }
        }
    ]
}